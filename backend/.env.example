# ─────────────────────────────────────────────
#  Infinity Barber – Backend Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Port the API server will listen on
PORT=3000

# PostgreSQL database connection URL (Supabase)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres"

# Supabase configuration for file storage
SUPABASE_URL="https://[PROJECT-ID].supabase.co"
SUPABASE_KEY="[YOUR-ANON-PUBLIC-KEY]"
SUPABASE_BUCKET="infinity-barber-uploads"

# Secret key used to sign JWT tokens – change this in production!
JWT_SECRET=change-this-to-a-long-random-string

# Comma-separated list of allowed frontend origins (CORS)
# In production, set this to your deployed Cloudflare Pages URL
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Admin panel credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Default password assigned to new barbers
DEFAULT_BARBER_PASSWORD=change-this-password

# Optional: GitHub personal access token (used for AI integrations)
# GITHUB_TOKEN=your-github-token-here

# Optional: AI model selection
# AI_MODEL=gpt-4o
